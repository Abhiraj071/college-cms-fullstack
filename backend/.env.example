# Copy this file to .env and fill in your values
PORT=5000
MONGODB_URI=mongodb://localhost:27017/college_cms
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
NODE_ENV=development
CORS_ORIGIN=http://localhost:5000
ADMIN_PASSWORD=change_this_in_production

# Email (SMTP) — optional, system works without it
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, use an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=CollegeOS <your_email@gmail.com>
